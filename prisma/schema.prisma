generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
  PARENT
}

enum AdmissionStatus {
  SUBMITTED
  REVIEWED
  APPROVED
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum InvoiceStatus {
  UNPAID
  PAID
  PARTIAL
  OVERDUE
}

enum PaymentMethod {
  CASH
  UPI
  BANK_TRANSFER
  CARD
  OTHER
}

enum NotificationType {
  FEE_DUE_REMINDER
  PAYMENT_CONFIRMATION
  ABSENCE_ALERT
  RESULT_ANNOUNCEMENT
  GENERAL_ANNOUNCEMENT
}

enum NotificationAudience {
  ALL_PARENTS
  PROGRAM_PARENTS
  STUDENT_PARENT
}

enum NotificationStatus {
  DRAFT
  SCHEDULED
  SENT
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum UserTokenType {
  PASSWORD_SETUP
  PASSWORD_RESET
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(PARENT)

  parentProfile ParentProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // audit relationships
  auditLogs          AuditLog[]
  markedAttendance   Attendance[]            @relation("AttendanceMarkedBy")
  createdInvoices    Invoice[]               @relation("InvoiceCreatedBy")
  recordedPayments   Payment[]               @relation("PaymentRecordedBy")
  uploadedPhotos     GalleryPhoto[]          @relation("PhotoUploadedBy")
  createdNotifications Notification[]        @relation("NotificationCreatedBy")
  notificationDeliveries NotificationDeliveryLog[] @relation("NotificationDeliveryRecipient")
  reviewedAdmissions AdmissionApplication[]  @relation("AdmissionReviewedBy")

  tokens UserToken[]
}

model ParentProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name  String
  phone String?

  students Student[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Program {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  students Student[]
  admissionApplications AdmissionApplication[]
  invoices Invoice[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdmissionApplication {
  id String @id @default(cuid())

  studentName String
  dateOfBirth DateTime
  age         Int

  parentName  String
  phoneNumber String
  email       String
  address     String

  programId String
  program   Program @relation(fields: [programId], references: [id], onDelete: Restrict)

  status        AdmissionStatus @default(SUBMITTED)
  decisionNotes String?

  reviewedAt  DateTime?
  reviewedById String?
  reviewedBy   User? @relation("AdmissionReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  approvedStudentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id String @id @default(cuid())

  fullName   String
  dateOfBirth DateTime
  age        Int
  address    String

  programId String
  program   Program @relation(fields: [programId], references: [id], onDelete: Restrict)

  parentProfileId String?
  parentProfile   ParentProfile? @relation(fields: [parentProfileId], references: [id], onDelete: SetNull)

  admissionDate DateTime @default(now())

  isArchived Boolean @default(false)
  archivedAt DateTime?

  attendance Attendance[]
  invoices   Invoice[]
  results    Result[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([programId])
  @@index([parentProfileId])
}

model Attendance {
  id String @id @default(cuid())

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  date   DateTime
  status AttendanceStatus
  remark String?

  markedById String?
  markedBy   User? @relation("AttendanceMarkedBy", fields: [markedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date])
  @@index([date])
}

model Invoice {
  id            String       @id @default(cuid())
  invoiceNumber String       @unique
  status        InvoiceStatus @default(UNPAID)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  programId String
  program   Program @relation(fields: [programId], references: [id], onDelete: Restrict)

  amountPaise Int
  currency    String @default("INR")

  dueDate DateTime

  createdById String?
  createdBy   User? @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  isArchived Boolean @default(false)
  archivedAt DateTime?

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([programId])
  @@index([dueDate])
}

model Payment {
  id String @id @default(cuid())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  amountPaise Int
  method      PaymentMethod @default(CASH)
  reference   String?
  paidAt      DateTime @default(now())

  recordedById String?
  recordedBy   User? @relation("PaymentRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
  @@index([paidAt])
}

model ExamTerm {
  id String @id @default(cuid())
  name String

  startDate DateTime?
  endDate   DateTime?

  isPublished Boolean @default(false)
  publishedAt DateTime?

  results Result[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Result {
  id String @id @default(cuid())

  termId String
  term   ExamTerm @relation(fields: [termId], references: [id], onDelete: Cascade)

  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  grade String?
  score Float?
  remarks String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([termId, studentId])
  @@index([studentId])
}

model GalleryCategory {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  photos GalleryPhoto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryPhoto {
  id String @id @default(cuid())

  categoryId String
  category   GalleryCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  title   String?
  caption String?
  takenAt DateTime?

  storageKey String
  publicUrl  String
  isPublic   Boolean @default(true)

  uploadedById String?
  uploadedBy   User? @relation("PhotoUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([isPublic])
}

model Notification {
  id String @id @default(cuid())

  type     NotificationType
  status   NotificationStatus @default(DRAFT)
  audience NotificationAudience @default(ALL_PARENTS)

  title   String
  message String

  programId String?
  program   Program? @relation(fields: [programId], references: [id], onDelete: SetNull)

  studentId String?
  student   Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  scheduledFor DateTime?
  sentAt       DateTime?

  createdById String?
  createdBy   User? @relation("NotificationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  deliveries NotificationDeliveryLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([scheduledFor])
}

model NotificationDeliveryLog {
  id String @id @default(cuid())

  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  channel NotificationChannel
  status  DeliveryStatus @default(PENDING)

  recipientUserId String?
  recipientUser   User? @relation("NotificationDeliveryRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)

  toAddress String
  providerMessageId String?
  error String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([notificationId])
  @@index([status])
}

model AuditLog {
  id String @id @default(cuid())

  actorId String?
  actor   User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  action     String
  entityType String
  entityId   String
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
}

model UserToken {
  id String @id @default(cuid())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  type UserTokenType
  token String @unique

  expiresAt DateTime
  usedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([expiresAt])
}

